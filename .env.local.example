# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets to .example files.

# Supabase — project URL + anon key from the project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — used by /api/intent (Claude Haiku intent classifier).
# Production/Preview keys live in Vercel Project Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...
